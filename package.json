{
  "name": "spectra",
  "version": "0.1.0",
  "description": "Desktop OpenAPI/Swagger editor",
  "main": "dist-electron/electron/main.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "dev": "npm run build:electron && node node_modules/concurrently/dist/bin/concurrently.js -k \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "node node_modules/vite/bin/vite.js",
    "dev:electron": "node node_modules/wait-on/bin/wait-on tcp:5173 && node node_modules/cross-env/src/bin/cross-env.js VITE_DEV_SERVER_URL=http://localhost:5173 node node_modules/electron/cli.js .",
    "build:electron": "node node_modules/typescript/bin/tsc -p tsconfig.electron.json",
    "build:electron:watch": "node node_modules/typescript/bin/tsc -p tsconfig.electron.json --watch",
    "build": "npm run build:electron && node node_modules/vite/bin/vite.js build",
    "dist": "npm run build && npx --yes electron-builder",
    "preview": "node node_modules/vite/bin/vite.js preview",
    "typecheck": "node node_modules/typescript/bin/tsc --noEmit && node node_modules/typescript/bin/tsc -p tsconfig.electron.json --noEmit",
    "rebuild:native": "npx --yes @electron/rebuild"
  },
  "dependencies": {
    "better-sqlite3": "^11.6.0",
    "electron-log": "^5.2.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "@electron/rebuild": "^3.7.0",
    "electron": "^28.3.3",
    "postcss": "^8.4.49",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "wait-on": "^8.0.1",
    "zustand": "^5.0.2"
  }
}
